<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Smart Sorter - Game Kebersihan</title>
    <style>
        body { margin: 0; font-family: 'Arial', sans-serif; background: #e0f7fa; overflow: hidden; text-align: center; }
        #game-container { position: relative; width: 100vw; height: 100vh; background: linear-gradient(#87CEEB, #f1f1f1); }
        
        .bin { position: absolute; bottom: 20px; width: 120px; height: 150px; border-radius: 10px 10px 5px 5px; color: white; font-weight: bold; display: flex; align-items: center; justify-content: center; }
        #organic-bin { left: 20%; background: #2e7d32; border: 4px solid #1b5e20; }
        #inorganic-bin { right: 20%; background: #1565c0; border: 4px solid #0d47a1; }
        
        .trash-item { position: absolute; width: 60px; height: 60px; cursor: grab; font-size: 40px; display: flex; align-items: center; justify-content: center; user-select: none; }
        
        #ui { position: absolute; top: 20px; width: 100%; font-size: 24px; pointer-events: none; }
    </style>
</head>
<body>

<div id="game-container">
    <div id="ui">Skor: <span id="score">0</span> | Nyawa: <span id="lives">3</span></div>
    
    <div id="organic-bin" class="bin">ORGANIK</div>
    <div id="inorganic-bin" class="bin">ANORGANIK</div>
</div>

<script>
    const container = document.getElementById('game-container');
    const scoreEl = document.getElementById('score');
    const livesEl = document.getElementById('lives');
    
    let score = 0;
    let lives = 3;
    const items = [
        { name: '🍎', type: 'organic' },
        { name: '🍌', type: 'organic' },
        { name: '🌿', type: 'organic' },
        { name: '🥤', type: 'inorganic' },
        { name: '🥫', type: 'inorganic' },
        { name: '🍾', type: 'inorganic' }
    ];

    function createTrash() {
        if (lives <= 0) return;

        const itemData = items[Math.floor(Math.random() * items.length)];
        const trash = document.createElement('div');
        trash.className = 'trash-item';
        trash.innerText = itemData.name;
        trash.style.left = Math.random() * (window.innerWidth - 60) + 'px';
        trash.style.top = '-60px';
        container.appendChild(trash);

        let fallInterval = setInterval(() => {
            let top = parseInt(trash.style.top);
            trash.style.top = (top + 3) + 'px';

            // Cek jika jatuh ke tanah
            if (top > window.innerHeight - 100) {
                clearInterval(fallInterval);
                container.removeChild(trash);
                updateLives(-1);
            }
        }, 20);

        // Mekanik Drag and Drop Sederhana
        trash.onmousedown = function(e) {
            clearInterval(fallInterval);
            trash.style.cursor = 'grabbing';

            function moveAt(pageX, pageY) {
                trash.style.left = pageX - trash.offsetWidth / 2 + 'px';
                trash.style.top = pageY - trash.offsetHeight / 2 + 'px';
            }

            function onMouseMove(e) { moveAt(e.pageX, e.pageY); }
            document.addEventListener('mousemove', onMouseMove);

            trash.onmouseup = function() {
                document.removeEventListener('mousemove', onMouseMove);
                checkCollision(trash, itemData.type);
            };
        };
    }

    function checkCollision(trash, type) {
        const rect = trash.getBoundingClientRect();
        const orgBin = document.getElementById('organic-bin').getBoundingClientRect();
        const inorgBin = document.getElementById('inorganic-bin').getBoundingClientRect();

        if (isOverlapping(rect, orgBin)) {
            if (type === 'organic') updateScore(10);
            else updateLives(-1);
            trash.remove();
        } else if (isOverlapping(rect, inorgBin)) {
            if (type === 'inorganic') updateScore(10);
            else updateLives(-1);
            trash.remove();
        } else {
            // Jika dilepas tidak di tong, lanjut jatuh
            // (Untuk kesederhanaan, kita hapus saja)
            trash.remove();
        }
    }

    function isOverlapping(rect1, rect2) {
        return !(rect1.right < rect2.left || rect1.left > rect2.right || rect1.bottom < rect2.top || rect1.top > rect2.bottom);
    }

    function updateScore(points) {
        score += points;
        scoreEl.innerText = score;
    }

    function updateLives(amount) {
        lives += amount;
        livesEl.innerText = lives;
        if (lives <= 0) {
            alert("Game Over! Skor Akhir Anda: " + score);
            location.reload();
        }
    }

    setInterval(createTrash, 2000);
</script>
</body>
</html>
